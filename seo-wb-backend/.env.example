APP_NAME="Seller WB AI Backend"
APP_ENV=local
APP_SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=120
JWT_BIND_USER_AGENT=true
DATABASE_URL=postgresql+psycopg://postgres:12345678@127.0.0.1:5432/seo_wb_db
DB_AUTO_CREATE=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3030,http://127.0.0.1:3030

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

OPENAI_API_KEY=
OPENAI_CARD_MODEL=

FAL_KEY=

ENCRYPTION_KEY=
WB_CONTENT_BASE_URL=https://content-api.wildberries.ru
ENABLE_WB_RAW_PROXY=false

AUTH_COOKIE_NAME=seller_wb_access
CSRF_COOKIE_NAME=seller_wb_csrf
ADMIN_AUTH_COOKIE_NAME=seller_wb_admin_access
ADMIN_CSRF_COOKIE_NAME=seller_wb_admin_csrf
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

AUTH_RATE_LIMIT_REQUESTS=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
GLOBAL_RATE_LIMIT_REQUESTS=240
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

MAX_GENERATE_IMAGES=8
MAX_UPLOAD_IMAGE_BYTES=10485760
MAX_JOB_FILES=30
MAX_MEDIA_UPLOAD_BYTES=15728640
MAX_CARD_PAYLOAD_BYTES=2097152

MAX_AI_CONCURRENCY=2
MAX_BACKGROUND_JOBS=2
OPENAI_IMAGE_CONCURRENCY=2
OPENAI_IMAGE_RETRY_ATTEMPTS=3
ENABLE_IMAGE_VALIDATION_RETRY=false
GENERATED_IMAGE_JPEG_QUALITY=88

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_HOST=
REDIS_USER=
REDIS_PASSWORD=
REDIS_SSL=false

RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=
RABBITMQ_SSL=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

WB_TIMEOUT_SECONDS=30
WB_MEDIA_TIMEOUT_SECONDS=120
WB_MAX_CONNECTIONS=50
WB_MAX_KEEPALIVE_CONNECTIONS=20
WB_RETRY_ATTEMPTS=3
WB_RETRY_BACKOFF_SECONDS=0.5
WB_CATALOG_CACHE_TTL_SECONDS=900
